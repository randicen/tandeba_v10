# OPENCODE_API_KEY: Required for the AI Agent (DeepSeek V4 Flash Free via OpenCode Zen).
# OpenCode Zen is an OpenAI-compatible gateway. Get your key at https://opencode.ai/auth
# Free models: deepseek-v4-flash-free (and others — see https://opencode.ai/docs/en/zen/).
# Set OPENCODE_MODEL to override the default model (default: deepseek-v4-flash-free).
OPENCODE_API_KEY=
# OPENCODE_MODEL=deepseek-v4-flash-free
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# E2B_API_KEY: Required for secure Python/JS code execution via E2B Sandboxes.
# You must obtain this from https://e2b.dev
E2B_API_KEY=

# OPENROUTER_API_KEY: Required for RAG / Embedding generation using Qwen3 via OpenRouter.
OPENROUTER_API_KEY=

# Xata Postgres URL for session/agent persistence
XATA_BRANCH_URL=

# Supabase credentials (VITE_ prefix so Vite exposes them to the client)
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Cloudflare R2 for Workspace Files persistence
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agent-workspace

# Apify Web Scraper API Token
# Get your token at https://console.apify.com
APIFY_API_TOKEN=

# VITE_DISABLE_HMR: Set to 'true' to disable Hot Module Replacement.
DISABLE_HMR=
